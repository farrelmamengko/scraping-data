<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> - Tender SKK Migas</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container mt-4">
        <h2 class="mb-4"><%= pageTitle %></h2>
        <p class="mb-3">Menampilkan tender yang sesuai dengan kemampuan produksi perusahaan.</p>

        <form action="/tender-perusahaan" method="GET" class="mb-3">
            <div class="input-group">
                <input type="text" class="form-control" name="keyword" placeholder="Cari lebih lanjut dalam hasil filter..." value="<%= typeof keyword !== 'undefined' ? keyword : '' %>">
                <button class="btn btn-primary" type="submit">Cari</button>
            </div>
        </form>

        <% if (tenders && tenders.length > 0) { %>
            <div class="row mt-4">
                <% tenders.forEach(tender => { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <%- include('partials/tender_card', { tender: tender, sourcePage: 'company_production' }) %>
                    </div>
                <% }); %>
            </div>
            <%- include('partials/pagination', { currentPage: currentPage, totalPages: totalPages, baseUrl: '/tender-perusahaan', keyword: keyword, status: null, type: null }) %>
        <% } else { %>
            <div class="alert alert-info mt-4" role="alert">
                Tidak ada tender yang ditemukan sesuai dengan kemampuan produksi perusahaan saat ini.
            </div>
        <% } %>

    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html> 